@model CitasApp.Models.Paciente

<h1>Nuevo Paciente</h1>
<form method="post">
    <label>Nombre:</label>
    <input asp-for="Nombre" /><br />
    <label>Apellido:</label>
    <input asp-for="Apellido" /><br />
    <label>Email:</label>
    <input asp-for="Email" /><br />
    <label>Telefono:</label>
    <input asp-for="Telefono" /><br /><br />
    <button type="submit">Guardar</button>
    <a asp-action="Index">Cancelar</a>
</form>