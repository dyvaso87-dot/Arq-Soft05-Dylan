@model CitasApp.Models.Paciente
@{
    ViewData["Title"] = "Editar paciente";
}

<section class="page-container">
    <div class="page-header">
        <div>
            <a asp-action="Index" class="btn-back">Volver</a>
            <h1 class="page-title">Editar Paciente</h1>
            <p class="page-subtitle">Mantén actualizados los datos de contacto del paciente.</p>
        </div>
    </div>
    <div class="form-card">
        <form method="post">
            <input asp-for="Id" type="hidden" />
            <div class="form-row">
                <div class="form-group"><label class="form-label">Nombre</label><input asp-for="Nombre" class="form-control-custom form-control" /></div>
                <div class="form-group"><label class="form-label">Apellido</label><input asp-for="Apellido" class="form-control-custom form-control" /></div>
                <div class="form-group"><label class="form-label">Email</label><input asp-for="Email" class="form-control-custom form-control" type="email" /></div>
                <div class="form-group"><label class="form-label">Teléfono</label><input asp-for="Telefono" class="form-control-custom form-control" /></div>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Guardar cambios</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</section>
