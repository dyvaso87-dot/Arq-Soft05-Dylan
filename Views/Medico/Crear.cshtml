@model CitasApp.Models.Medico
@{
    ViewData["Title"] = "Nuevo médico";
}

<section class="page-container">
    <div class="page-header">
        <div>
            <a asp-action="Index" class="btn-back">Volver</a>
            <h1 class="page-title">Nuevo Médico</h1>
            <p class="page-subtitle">Agrega especialistas con credenciales y especialidad visibles para la operación clínica.</p>
        </div>
    </div>
    <div class="form-card">
        <form method="post">
            <div class="form-row">
                <div class="form-group"><label class="form-label">Nombre</label><input asp-for="Nombre" class="form-control-custom form-control" placeholder="Ej: Carlos" /></div>
                <div class="form-group"><label class="form-label">Apellido</label><input asp-for="Apellido" class="form-control-custom form-control" placeholder="Ej: Reyes" /></div>
                <div class="form-group"><label class="form-label">Especialidad</label><input asp-for="Especialidad" class="form-control-custom form-control" placeholder="Ej: Cardiología" /></div>
                <div class="form-group"><label class="form-label">Número de licencia</label><input asp-for="NumeroLicencia" class="form-control-custom form-control" placeholder="Ej: MG-10421" /></div>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Guardar</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</section>
