@{
    ViewData["Title"] = "Home Page";
}

<div class="text-center">
    <h1 class="display-4">Bienvenido a Citas App</h1>
    <p>Selecciona una seccion para comenzar</p>
</div>

<div style="display: flex; gap: 20px; justify-content: center; margin-top: 40px;">

    <a asp-controller="Cita" asp-action="Index"
           style="display:block; width:180px; padding:30px; background:#0d6efd; color:white;
        text-align:center; text-decoration:none; border-radius:8px; font-size:18px;">
        🗓 Citas
    </a>

    <a asp-controller="Medico" asp-action="Index"
           style="display:block; width:180px; padding:30px; background:#198754; color:white;
        text-align:center; text-decoration:none; border-radius:8px; font-size:18px;">
        🩺 Medicos
    </a>

    <a asp-controller="Paciente" asp-action="Index"
           style="display:block; width:180px; padding:30px; background:#dc3545; color:white;
        text-align:center; text-decoration:none; border-radius:8px; font-size:18px;">
        👤 Pacientes
    </a>

</div>