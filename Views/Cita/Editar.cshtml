@model CitasApp.CitasApp.Domian.Models.Cita
@using CitasApp.CitasApp.Domian.Models
@{
    ViewData["Title"] = "Editar cita";
    var pacientes = ViewBag.Pacientes as List<Paciente>;
    var medicos = ViewBag.Medicos as List<Medico>;
}

<section class="page-container">
    <div class="page-header">
        <div>
            <a asp-action="Index" class="btn-back">Volver</a>
            <h1 class="page-title">Editar Cita</h1>
            <p class="page-subtitle">Actualiza horario, paciente, médico o estado de la consulta.</p>
        </div>
    </div>

    <div class="form-card appointment-form">
        <form method="post">
            <input asp-for="Id" type="hidden" />
            <div class="form-row">
                <div class="form-group">
                    <label class="form-label">Paciente</label>
                    <select asp-for="PacienteId" class="form-control-custom form-select">
                        @foreach (var p in pacientes!)
                        {
                            <option value="@p.Id">@p.Nombre @p.Apellido</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Médico</label>
                    <select asp-for="MedicoId" class="form-control-custom form-select">
                        @foreach (var m in medicos!)
                        {
                            <option value="@m.Id">Dr. @m.Nombre @m.Apellido</option>
                        }
                    </select>
                </div>
                <div class="form-group">
                    <label class="form-label">Fecha</label>
                    <input asp-for="Fecha" type="date" class="form-control-custom form-control" />
                </div>
                <div class="form-group">
                    <label class="form-label">Hora</label>
                    <input asp-for="Hora" type="time" class="form-control-custom form-control" />
                </div>
                <div class="form-group form-span">
                    <label class="form-label">Motivo</label>
                    <input asp-for="Motivo" class="form-control-custom form-control" />
                </div>
                <div class="form-group">
                    <label class="form-label">Estado</label>
                    <select asp-for="Estado" class="form-control-custom form-select">
                        <option>Pendiente</option>
                        <option>Confirmada</option>
                        <option>Cancelada</option>
                    </select>
                </div>
            </div>
            <div class="form-actions">
                <button type="submit" class="btn btn-primary">Guardar cambios</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</section>
