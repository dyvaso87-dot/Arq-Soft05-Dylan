@model List<CitasApp.CitasApp.Domian.Models.Cita>
@using CitasApp.CitasApp.Domian.Models

@{
    ViewData["Title"] = "Citas por paciente";
    var pacientes = ViewBag.Pacientes as List<Paciente>;
    var medicos = ViewBag.Medicos as List<Medico>;
    var primero = Model.FirstOrDefault();
    var paciente = pacientes?.FirstOrDefault(p => p.Id == primero?.PacienteId);
}

<section class="page-container">
    <div class="page-header">
        <div>
            <a asp-controller="Cita" asp-action="Index" class="btn-back">Todas las citas</a>
            <h1 class="page-title">Citas de @(paciente != null ? $"{paciente.Nombre} {paciente.Apellido}" : "paciente")</h1>
            <p class="page-subtitle">Historial de agenda filtrado por paciente.</p>
        </div>
    </div>

    <div class="table-card table-responsive">
        <table class="table modern-table">
            <thead>
                <tr><th>Fecha</th><th>Hora</th><th>Médico</th><th>Motivo</th><th>Estado</th></tr>
            </thead>
            <tbody>
                @foreach (var c in Model)
                {
                    var medico = medicos?.FirstOrDefault(m => m.Id == c.MedicoId);
                    var estado = c.Estado?.ToLowerInvariant() ?? "pendiente";
                    <tr>
                        <td>@c.Fecha.ToString("dd/MM/yyyy")</td>
                        <td>@c.Hora.ToString("HH:mm")</td>
                        <td>@(medico != null ? $"Dr. {medico.Nombre} {medico.Apellido}" : "Sin médico")</td>
                        <td>@c.Motivo</td>
                        <td><span class="status-badge status-@estado">@c.Estado</span></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</section>
